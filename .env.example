# ============================================================
# JARVIS - Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais
# cp .env.example .env
# ============================================================

# --- LiveKit ---
# URL do servidor LiveKit (ex: wss://seu-projeto.livekit.cloud)
LIVEKIT_URL=wss://your-livekit-server.livekit.cloud

# Chave pública da API LiveKit
LIVEKIT_API_KEY=your_livekit_api_key

# Segredo da API LiveKit
LIVEKIT_API_SECRET=your_livekit_api_secret

# --- Google (LLM + Voz) ---
# Chave da API Google (usada pelo plugin google.beta.realtime)
GOOGLE_API_KEY=your_google_api_key

# --- Mem0 (Memória Persistente) ---
# Chave da API Mem0 (obtenha em https://mem0.ai)
MEM0_API_KEY=your_mem0_api_key

# --- Configuração do Usuário ---
# ID do usuário para isolamento de memória no Mem0
# Padrão: PedroHenrique
JARVIS_USER_ID=PedroHenrique
